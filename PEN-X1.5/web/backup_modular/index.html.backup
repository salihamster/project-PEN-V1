<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PEN Agent</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="style.css?v=13" />
</head>
<body>
    <div class="app">
        <!-- Header -->
        <header class="app-header">
            <div class="header-left">
                <div class="app-logo">
                    <i class="fas fa-bolt"></i>
                </div>
                <h1 class="app-title">PEN Agent</h1>
                <span class="connection-status" id="connectionIndicator">
                    <span class="status-dot"></span>
                </span>
            </div>
            <div class="header-right">
                <div class="chat-menu-wrapper">
                    <button class="header-btn" id="chatMenuBtn" title="Daha fazla">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                    <div class="chat-menu-dropdown" id="chatMenuDropdown">
                        <button class="chat-menu-item" id="menuSleepBtn">
                            <i class="fas fa-moon"></i>
                            <span>Uyku Döngüsü</span>
                        </button>
                        <button class="chat-menu-item danger" id="menuResetBtn">
                            <i class="fas fa-trash-alt"></i>
                            <span>Sohbeti Sil</span>
                        </button>
                    </div>
                </div>
                <button class="header-btn" id="settingsBtn" title="Ayarlar">
                    <i class="fas fa-cog"></i>
                </button>
                <div class="user-avatar">
                    <span>S</span>
                </div>
            </div>
        </header>

        <!-- File Preview Panel (Fixed, outside grid) -->
        <aside class="file-preview-panel" id="filePreviewPanel">
            <div class="sidebar-header">
                <div class="sidebar-header-top">
                    <button class="sidebar-close-btn" id="filePreviewCloseBtn" title="Kapat">
                        <i class="fas fa-times"></i>
                    </button>
                    <span class="sidebar-title" id="filePreviewTitle">Dosya İçeriği</span>
                </div>
                <div class="file-preview-actions">
                    <button class="preview-action-btn" id="previewZoomIn" title="Yakınlaştır">
                        <i class="fas fa-search-plus"></i>
                    </button>
                    <button class="preview-action-btn" id="previewZoomOut" title="Uzaklaştır">
                        <i class="fas fa-search-minus"></i>
                    </button>
                    <button class="preview-action-btn" id="previewDownload" title="İndir">
                        <i class="fas fa-download"></i>
                    </button>
                </div>
            </div>
            <div class="sidebar-content file-preview-content" id="filePreviewContent">
                <pre id="filePreviewText"></pre>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- History Sidebar (Left) -->
            <aside class="sidebar history-sidebar" id="historySidebar">
                <div class="sidebar-header">
                    <div class="sidebar-header-top">
                        <button class="sidebar-close-btn" id="sidebarCloseBtn" title="Kapat">
                            <i class="fas fa-times"></i>
                        </button>
                        <span class="sidebar-title">Sohbet Geçmişi</span>
                    </div>
                    <div class="sidebar-search">
                        <i class="fas fa-search"></i>
                        <input type="text" id="historySearchInput" placeholder="Sohbetlerde ara...">
                    </div>
                </div>
                <div class="sidebar-content">
                    <div class="history-list" id="historyList">
                        <!-- History items will be populated by JS with date groups -->
                        <div class="history-empty" id="historyEmpty">
                            <i class="fas fa-history"></i>
                            <span>Henüz arşivlenmiş sohbet yok</span>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Chat Panel -->
            <section class="panel chat-panel">
                <div class="panel-body chat-body" id="chatMessages">
                    <div class="messages-content" id="messagesContent" aria-live="polite">
                        <div class="welcome-message" id="welcomeMessage">
                            <div class="welcome-icon">
                                <i class="fas fa-bolt"></i>
                            </div>
                            <h3>Merhaba! Ben PEN</h3>
                            <p>WhatsApp, email, Drive ve hafıza verilerinizle ilgili size yardımcı olmak için buradayım.</p>
                            <div class="welcome-suggestions">
                                <button class="suggestion-chip" data-text="WhatsApp'ta 'toplantı' ara">
                                    <i class="fas fa-search"></i> WhatsApp'ta ara
                                </button>
                                <button class="suggestion-chip" data-text="Son 3 günde neler oldu?">
                                    <i class="fas fa-clock"></i> Son 3 günü özetle
                                </button>
                                <button class="suggestion-chip" data-text="Neler yapabilirsin?">
                                    <i class="fas fa-magic"></i> Neler yapabilirsin?
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Chat Input (hidden when viewing archived) -->
                <div class="chat-input-area" id="chatInputArea">
                    <!-- Attached Files -->
                    <div class="attached-files" id="attachedFiles"></div>
                    <div class="input-container" id="inputContainer">
                        <textarea id="messageInput" placeholder="Yazmaya başlayın..." rows="1" aria-label="Mesaj girişi"></textarea>
                        <div class="input-footer">
                            <div class="input-footer-left">
                                <div class="model-selector-wrapper">
                                    <button class="model-selector-btn" id="modelSelectorBtn" title="Model seç">
                                        <span class="model-name" id="selectedModelName">Gemini 2.5 Flash</span>
                                        <i class="fas fa-chevron-down"></i>
                                    </button>
                                    <div class="model-dropdown" id="modelDropdown">
                                        <div class="model-dropdown-content" id="modelDropdownContent">
                                            <!-- Models will be populated by JS -->
                                        </div>
                                    </div>
                                </div>
                                <div class="input-toolbox">
                                    <button class="toolbox-btn" id="attachFileBtn" title="Dosya ekle">
                                        <i class="fas fa-paperclip"></i>
                                    </button>
                                    <input type="file" id="fileInput" multiple accept="image/*,.pdf,.txt,.md,.json,.csv,.py,.js,.html,.css,.doc,.docx" style="display:none">
                                    <button class="toolbox-btn" id="exportChatBtn" title="Sohbeti dışa aktar">
                                        <i class="fas fa-download"></i>
                                    </button>
                                </div>
                            </div>
                            <button class="send-btn" id="sendBtn" aria-label="Mesaj gönder">
                                <i class="fas fa-arrow-up"></i>
                            </button>
                        </div>
                    </div>
                    <div class="input-disclaimer">
                        PENNY yapay zeka destekli bir asistandır,içerilen yapay zeka desteği sonucu hata yapabilir. Önemli bilgileri iki kez doğrulayın.
                    </div>
                </div>
            </section>

            <!-- Sidebar Toggle Button (Left) -->
            <button class="sidebar-panel-toggle" id="sidebarToggle" title="Sohbet geçmişi">
                <i class="fas fa-bars"></i>
            </button>

            <!-- Tools Panel Toggle Button (Right) -->
            <button class="tools-panel-toggle" id="toolsPanelToggle" title="Araç panelini aç/kapat">
                <i class="fas fa-wrench"></i>
            </button>

            <!-- Tools Panel -->
            <aside class="panel tools-panel" id="toolsPanel">
                <div class="panel-header">
                    <span class="panel-title">Araç Aktivitesi</span>
                    <div class="panel-actions">
                        <button class="panel-btn" id="toolOutputToggle" title="Detayları göster/gizle">
                            <i class="fas fa-eye"></i>
                        </button>
                        <button class="panel-btn" id="closePanelBtn" title="Paneli kapat">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
                <div class="panel-body">
                    <div class="tools-body" id="toolsBody">
                        <div class="tools-empty" id="toolsEmpty">
                            <i class="fas fa-wrench"></i>
                            <span>Henüz araç kullanılmadı</span>
                        </div>
                    </div>
                </div>
            </aside>
        </main>
    </div>

    <!-- Settings Page -->
    <div class="settings-page" id="settingsPage">
        <div class="settings-layout">
            <!-- Left Sidebar -->
            <div class="settings-sidebar">
                <button class="settings-back-btn" id="settingsBackBtn">
                    <i class="fas fa-arrow-left"></i>
                    Geri
                </button>
                <nav class="settings-nav">
                    <button class="settings-nav-item active" data-tab="apikeys">API Anahtarlari</button>
                    <button class="settings-nav-item" data-tab="datasync">Veri Guncelleme</button>
                    <button class="settings-nav-item" data-tab="email">Email Ayarlari</button>
                    <button class="settings-nav-item" data-tab="permissions">Izinler</button>
                    <button class="settings-nav-item" data-tab="profile">Hafiza (L4)</button>
                    <button class="settings-nav-item" data-tab="appearance">Gorunum</button>
                </nav>
            </div>

            <!-- Right Content -->
            <div class="settings-main">
                <!-- API Keys -->
                <div class="settings-panel active" id="panelApikeys">
                    <h2 class="settings-panel-title">API Anahtarlari</h2>
                    <p class="settings-panel-desc">Model saglayicilarinin API anahtarlarini buradan yonetin.</p>
                    
                    <div class="settings-field">
                        <label class="settings-field-label">Google AI (Gemini)</label>
                        <div class="settings-field-row">
                            <input type="password" class="settings-input" id="inputGeminiKey" placeholder="API anahtarini girin...">
                            <button class="settings-field-btn" onclick="togglePasswordVisibility('inputGeminiKey', this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span class="settings-field-status" id="statusGemini"></span>
                    </div>

                    <div class="settings-field">
                        <label class="settings-field-label">OpenAI</label>
                        <div class="settings-field-row">
                            <input type="password" class="settings-input" id="inputOpenaiKey" placeholder="API anahtarini girin...">
                            <button class="settings-field-btn" onclick="togglePasswordVisibility('inputOpenaiKey', this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span class="settings-field-status" id="statusOpenai"></span>
                    </div>

                    <div class="settings-field">
                        <label class="settings-field-label">Anthropic (Claude)</label>
                        <div class="settings-field-row">
                            <input type="password" class="settings-input" id="inputAnthropicKey" placeholder="API anahtarini girin...">
                            <button class="settings-field-btn" onclick="togglePasswordVisibility('inputAnthropicKey', this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span class="settings-field-status" id="statusAnthropic"></span>
                    </div>

                    <div class="settings-field">
                        <label class="settings-field-label">Brave Search</label>
                        <div class="settings-field-row">
                            <input type="password" class="settings-input" id="inputBraveKey" placeholder="API anahtarini girin...">
                            <button class="settings-field-btn" onclick="togglePasswordVisibility('inputBraveKey', this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span class="settings-field-status" id="statusBrave"></span>
                    </div>

                    <button class="settings-save-btn" id="saveApiKeysBtn">Kaydet</button>
                </div>

                <!-- Data Sync -->
                <div class="settings-panel" id="panelDatasync">
                    <h2 class="settings-panel-title">Veri Guncelleme</h2>
                    <p class="settings-panel-desc">WhatsApp, Email ve Drive verilerinizi guncelleyin.</p>

                    <div class="sync-section">
                        <div class="sync-info-box">
                            <i class="fab fa-whatsapp"></i>
                            <div class="sync-info-text">
                                <strong>WhatsApp</strong>
                                <span>Google Drive'daki WhatsApp exportlarini indirir ve isler.</span>
                            </div>
                        </div>
                        <div class="sync-info-box">
                            <i class="fas fa-envelope"></i>
                            <div class="sync-info-text">
                                <strong>Email</strong>
                                <span>IMAP uzerinden mailleri ceker (aktifse).</span>
                            </div>
                        </div>
                    </div>

                    <div class="sync-status" id="syncStatus"></div>
                    <div class="sync-log" id="syncLog"></div>

                    <button class="settings-save-btn sync-btn" id="runSyncBtn">
                        <i class="fas fa-sync-alt"></i>
                        Simdi Guncelle
                    </button>
                </div>

                <!-- Email Settings -->
                <div class="settings-panel" id="panelEmail">
                    <h2 class="settings-panel-title">Email Ayarlari</h2>
                    <p class="settings-panel-desc">IMAP email baglantisi icin ayarlar.</p>

                    <div class="settings-field">
                        <label class="settings-field-label">Email Adresi</label>
                        <input type="email" class="settings-input" id="inputEmailAddress" placeholder="ornek@gmail.com">
                    </div>

                    <div class="settings-field">
                        <label class="settings-field-label">Email Sifresi / App Password</label>
                        <div class="settings-field-row">
                            <input type="password" class="settings-input" id="inputEmailPassword" placeholder="Uygulama sifresi">
                            <button class="settings-field-btn" onclick="togglePasswordVisibility('inputEmailPassword', this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="settings-field">
                        <label class="settings-field-label">IMAP Sunucusu</label>
                        <input type="text" class="settings-input" id="inputImapServer" placeholder="imap.gmail.com">
                    </div>

                    <div class="settings-field">
                        <label class="settings-field-label">IMAP Port</label>
                        <input type="number" class="settings-input" id="inputImapPort" placeholder="993">
                    </div>

                    <button class="settings-save-btn" id="saveEmailBtn">Kaydet</button>
                </div>

                <!-- Permissions -->
                <div class="settings-panel" id="panelPermissions">
                    <h2 class="settings-panel-title">Izinler</h2>
                    <p class="settings-panel-desc">Hangi araclara erisim izni verilecegini secin.</p>

                    <div class="settings-toggle-item">
                        <div class="settings-toggle-info">
                            <span class="settings-toggle-label">WhatsApp</span>
                            <span class="settings-toggle-desc">WhatsApp mesajlarina erisim</span>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="toolWhatsapp" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="settings-toggle-item">
                        <div class="settings-toggle-info">
                            <span class="settings-toggle-label">Email</span>
                            <span class="settings-toggle-desc">Email okuma erisimi</span>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="toolEmail">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="settings-toggle-item">
                        <div class="settings-toggle-info">
                            <span class="settings-toggle-label">Google Drive</span>
                            <span class="settings-toggle-desc">Drive dosyalarina erisim</span>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="toolDrive" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="settings-toggle-item">
                        <div class="settings-toggle-info">
                            <span class="settings-toggle-label">Web Arama</span>
                            <span class="settings-toggle-desc">Internet aramasi yapabilme</span>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="toolWeb">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="settings-toggle-item">
                        <div class="settings-toggle-info">
                            <span class="settings-toggle-label">Hafiza (L4)</span>
                            <span class="settings-toggle-desc">Uzun vadeli hafiza erisimi</span>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" id="toolMemory" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>

                <!-- L4 Profile -->
                <div class="settings-panel" id="panelProfile">
                    <h2 class="settings-panel-title">Hafiza (L4)</h2>
                    <p class="settings-panel-desc">Model sizin hakkınızda ne biliyor?</p>

                    <div id="l4ProfileBox" class="l4-container">
                        <div class="l4-loading">Yukleniyor...</div>
                    </div>
                </div>

                <!-- Appearance -->
                <div class="settings-panel" id="panelAppearance">
                    <h2 class="settings-panel-title">Gorunum</h2>
                    <p class="settings-panel-desc">Arayuz gorunumunu ozellestirin.</p>

                    <div class="settings-field">
                        <label class="settings-field-label">Renk Temasi</label>
                        <select class="settings-select" id="themeSelect">
                            <option value="dark">Koyu</option>
                            <option value="light">Acik</option>
                            <option value="system">Sistem</option>
                        </select>
                    </div>

                    <div class="settings-field">
                        <label class="settings-field-label">Yazi Boyutu</label>
                        <select class="settings-select" id="fontSizeSelect">
                            <option value="small">Kucuk</option>
                            <option value="medium" selected>Orta</option>
                            <option value="large">Buyuk</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Archived Chat Page -->
    <div class="archived-chat-page" id="archivedChatPage">
        <header class="app-header">
            <div class="header-left">
                <h1 class="app-title" id="archivedChatTitle">Eski Sohbet</h1>
            </div>
            <div class="header-right">
                <button class="header-btn" id="archivedBackBtn" title="Ana Sohbete Dön">
                    <i class="fas fa-arrow-right"></i>
                </button>
                <div class="app-logo-link" id="archivedLogoBtn" title="Ana Sohbete Dön">
                    <div class="app-logo">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <span class="app-title">PEN Agent</span>
                </div>
            </div>
        </header>
        <main class="archived-chat-layout">
            <section class="archived-chat-content">
                <div class="archived-messages" id="archivedMessages"></div>
            </section>
            <aside class="sidebar history-sidebar archived-history-panel">
                <div class="sidebar-header">
                    <div class="sidebar-header-top">
                        <div class="app-logo">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <span class="sidebar-title">Sohbet Geçmişi</span>
                    </div>
                    <div class="sidebar-search">
                        <i class="fas fa-search"></i>
                        <input type="text" id="archivedHistorySearch" placeholder="Sohbetlerde ara...">
                    </div>
                </div>
                <div class="sidebar-content">
                    <div class="history-list" id="archivedHistoryList"></div>
                </div>
            </aside>
        </main>
    </div>

    <script src="script.js?v=13"></script>
</body>
</html>
